{
  "name": "octotray",
  "version": "1.0.4",
  "description": "Electron tray app for OctoPrint status (temps, job, time)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "OctoTray contributors",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.octotray.app",
    "productName": "OctoTray",
    "copyright": "Copyright © OctoTray contributors",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "preload/**/*.js",
      "renderer/**/*",
      "config.example.json",
      "tray.png",
      "tray@2x.png"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "octotray@users.noreply.github.com",
      "synopsis": "OctoPrint tray monitor"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["en_US"]
    }
  }
}
